# ─────────────────────────────────────────────
# DIRECTRONICS ServiceFlow ERP — Backend .env.example
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# Database — PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/DIRECTRONICS"

# JWT — Use strong random secrets (min 64 chars) in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_access_token_secret_min_64_chars"
JWT_REFRESH_SECRET="your_refresh_token_secret_min_64_chars_different_from_above"

# Token expiry
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_DAYS=7

# CORS — Frontend origin (no trailing slash)
FRONTEND_ORIGIN="http://localhost:3000"

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=20

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Logging
LOG_LEVEL=debug
